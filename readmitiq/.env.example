# ── ReadmitIQ Environment Configuration ─────────────────────────
# Copy to .env and customize for your environment

# Application
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Database
DATABASE_URL=postgresql+asyncpg://readmitiq:readmitiq@localhost:5432/readmitiq
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS (comma-separated JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ML / Models
MODEL_DIR=./models
RISK_THRESHOLD_HIGH=0.70
RISK_THRESHOLD_MEDIUM=0.40
SHAP_MAX_DISPLAY_FEATURES=15

# Optuna
OPTUNA_N_TRIALS=50

# Security (CHANGE IN PRODUCTION)
JWT_SECRET=jwt-secret-change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
